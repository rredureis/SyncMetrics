{
  "Pipeline": {
    "Locations": [
      {
        "Name": "New York",
        "Latitude": 40.7128,
        "Longitude": -74.0060
      },
      {
        "Name": "London",
        "Latitude": 51.5074,
        "Longitude": -0.1278
      },
      {
        "Name": "Tokyo",
        "Latitude": 35.6762,
        "Longitude": 139.6503
      }
    ],
    "Sources": {
      "Wttr": {
        "BaseUrl": "https://wttr.in",
        "FieldMappings": [
          { "Source": "maxtempC",            "Target": "TemperatureMaxC", "Type": "decimal" },
          { "Source": "mintempC",            "Target": "TemperatureMinC", "Type": "decimal" },
          { "Source": "precipitation_sum_mm","Target": "PrecipitationMm", "Type": "decimal" },
          { "Source": "windspeed_max_kmph",  "Target": "WindSpeedMaxKmh", "Type": "decimal" },
          { "Source": "uvIndex",             "Target": "UvIndexMax",      "Type": "decimal" }
        ]
      },
      "OpenMeteo": {
        "BaseUrl": "https://api.open-meteo.com/v1/forecast",
        "DailyFields": "temperature_2m_max,temperature_2m_min,precipitation_sum,wind_speed_10m_max,uv_index_max",
        "ForecastDays": 7,
        "FieldMappings": [
          {
            "Source": "temperature_2m_max",
            "Target": "TemperatureMaxC",
            "Type": "decimal"
          },
          {
            "Source": "temperature_2m_min",
            "Target": "TemperatureMinC",
            "Type": "decimal"
          },
          {
            "Source": "precipitation_sum",
            "Target": "PrecipitationMm",
            "Type": "decimal"
          },
          {
            "Source": "wind_speed_10m_max",
            "Target": "WindSpeedMaxKmh",
            "Type": "decimal"
          },
          {
            "Source": "uv_index_max",
            "Target": "UvIndexMax",
            "Type": "decimal"
          }
        ]
      }
    },
    "Output": {
      "Directory": "output",
      "FilePrefix": "weather_normalized"
    },
    "Retry": {
      "MaxRetries": 3,
      "BaseDelaySeconds": 2
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}